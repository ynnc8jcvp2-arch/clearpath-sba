# Vercel Deployment Ignore File
# Files/directories to exclude from deployment

# Environment files (only needed locally)
.env.local
.env.*.local

# Development tools
.vscode/
.idea/
.eslintrc*
.prettierrc*

# OS files
.DS_Store
*.swp
*.swo

# Version control
.git/
.gitignore

# Documentation (optional, can include if needed)
# *.md

# Dependencies — let Vercel install fresh (node_modules committed to git causes file-count limits)
node_modules/

# Built output — Vercel builds from source
dist/

# Test files
tests/
